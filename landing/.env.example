# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Creem (billing)
CREEM_API_KEY=
CREEM_PRODUCT_ID=
CREEM_WEBHOOK_SECRET=

# Included AI (server-side only — never exposed to the extension or any client)
GEMINI_API_KEY=
CRON_SECRET=
# HMAC salt for hashing client IPs before they're used as rate-limit keys or
# stored in ai_usage_log — required for per-IP rate limiting to activate; if
# unset, hashedClientIp() returns null and that layer is silently skipped
# rather than ever falling back to a raw IP. Generate with:
#   openssl rand -hex 32
IP_HASH_SALT=

# Chrome extension
NEXT_PUBLIC_AMINTA_EXTENSION_IDS=

# PostHog
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
NEXT_PUBLIC_POSTHOG_HOST=
