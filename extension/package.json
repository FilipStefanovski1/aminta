{
  "name": "aminta",
  "displayName": "Aminta",
  "version": "0.1.1",
  "description": "Aminta - Your AI writing companion for X.",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package",
    "test": "vitest run"
  },
  "dependencies": {
    "plasmo": "latest",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@types/chrome": "0.0.258",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "autoprefixer": "10.4.17",
    "postcss": "8.4.33",
    "tailwindcss": "3.4.1",
    "typescript": "5.3.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^2.1.9"
  },
  "icons": {
    "16": "assets/icon16.png",
    "32": "assets/icon32.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "manifest": {
    "permissions": [
      "storage",
      "sidePanel",
      "tabs",
      "identity",
      "scripting"
    ],
    "host_permissions": [
      "https://x.com/*",
      "https://twitter.com/*",
      "https://www.linkedin.com/*",
      "https://openrouter.ai/*",
      "https://api.groq.com/*",
      "https://generativelanguage.googleapis.com/*",
      "https://amintaapp.com/*",
      "https://www.amintaapp.com/*"
    ],
    "externally_connectable": {
      "matches": [
        "https://amintaapp.com/*"
      ]
    },
    "action": {
      "default_title": "Open Aminta"
    },
    "oauth2": {
      "client_id": "110269399450-vfmckhcemps4s9k3okeb1ebh4bk17po7.apps.googleusercontent.com",
      "scopes": [
        "openid",
        "email",
        "profile"
      ]
    }
  }
}
